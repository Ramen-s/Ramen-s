    <%= link_to "LOGO", admin_root_path, class: "nc-logo" %>

    <div class="nc-header__right">
      <nav class="nc-nav">
        <%= link_to "商品一覧", admin_items_path, class: "nc-btn" %>
        <%= link_to "会員一覧", admin_customers_path, class: "nc-btn" %>
