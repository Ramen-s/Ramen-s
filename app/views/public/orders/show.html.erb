<div class="container">
  <h3 class="my-4"><span class="bg-light px-3">注文履歴詳細</span></h3>

  <div class="row mb-4">
    <div class="col-md-8">
      <h5 class="fw-bold">注文情報</h5>
      <table class="table table-bordered">
        <tr>
          <th class="table-light w-25">注文日</th>
          <td><%= @order.created_at.strftime('%Y/%m/%d') %></td>
        </tr>
        <tr>
          <th class="table-light">配送先</th>
          <td>
            〒<%= @order.postal_code %><br>
            <%= @order.address %><br>
            <%= @order.name %>
          </td>
        </tr>
        <tr>
          <th class="table-light">支払方法</th>
          <td><%= @order.payment_method_i18n %></td>
        </tr>
        <tr>
          <th class="table-light">ステータス</th>
          <td><%= @order.status_i18n %></td>
        </tr>
      </table>
    </div>

    <div class="col-md-4">
      <h5 class="fw-bold">請求情報</h5>
      <table class="table table-bordered">
        <tr>
          <th class="table-light w-50">商品合計</th>
          <td><%= number_with_delimiter(@order.total_payment - @order.shipping_cost) %></td>
        </tr>
        <tr>
          <th class="table-light">配送料</th>
          <td><%= number_with_delimiter(@order.shipping_cost) %></td>
        </tr>
        <tr>
          <th class="table-light">ご請求額</th>
          <td><%= number_with_delimiter(@order.total_payment) %></td>
        </tr>
      </table>
    </div>
  </div>

  <h5 class="fw-bold">注文内容</h5>
  <table class="table table-bordered">
    <thead class="table-light">
      <tr>
        <th>商品</th>
        <th>単価（税込）</th>
        <th>個数</th>
        <th>小計</th>
      </tr>
    </thead>
    <tbody>
      <% @order_details.each do |order_detail| %>
        <tr>
          <td><%= order_detail.item.name %></td>
          <td><%= number_with_delimiter(order_detail.price) %></td>
          <td><%= order_detail.amount %></td>
          <td><%= number_with_delimiter(order_detail.price * order_detail.amount) %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
