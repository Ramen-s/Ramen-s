<div class="container">
  <div class="row">
    <div class="col-md-10 offset-md-1">
      
      <!-- タイトル -->
      <h4 class="mb-4 mt-4"><span class="bg-light px-4 py-2">新規会員登録</span></h4>

      <%= form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>

        <!-- 名前 -->
        <div class="form-group row">
          <label class="col-md-3 col-form-label">名前</label>
          <div class="col-md-9 d-flex align-items-center">
            <span class="mr-2">(姓)</span>
            <%= f.text_field :last_name, class: "form-control mr-4", style: "width: 200px;" %>
            <span class="mr-2">(名)</span>
            <%= f.text_field :first_name, class: "form-control", style: "width: 200px;" %>
          </div>
        </div>

        <!-- フリガナ -->
        <div class="form-group row">
          <label class="col-md-3 col-form-label">フリガナ</label>
          <div class="col-md-9 d-flex align-items-center">
            <span class="mr-2">(セイ)</span>
            <%= f.text_field :last_name_kana, class: "form-control mr-4", style: "width: 200px;" %>
            <span class="mr-2">(メイ)</span>
            <%= f.text_field :first_name_kana, class: "form-control", style: "width: 200px;" %>
          </div>
        </div>

        <!-- メールアドレス -->
        <div class="form-group row">
          <label class="col-md-3 col-form-label">メールアドレス</label>
          <div class="col-md-7">
            <%= f.email_field :email, autocomplete: "email", class: "form-control", placeholder: "sample@example.com" %>
          </div>
        </div>

        <!-- 郵便番号 -->
        <div class="form-group row">
          <label class="col-md-3 col-form-label">郵便番号(ハイフンなし)</label>
          <div class="col-md-7">
            <%= f.text_field :postal_code, class: "form-control", placeholder: "0000000" %>
          </div>
        </div>

        <!-- 住所 -->
        <div class="form-group row">
          <label class="col-md-3 col-form-label">住所</label>
          <div class="col-md-7">
            <%= f.text_field :address, class: "form-control", placeholder: "東京都渋谷区代々木神園町0-0" %>
          </div>
        </div>

        <!-- 電話番号 -->
        <div class="form-group row">
          <label class="col-md-3 col-form-label">電話番号(ハイフンなし)</label>
          <div class="col-md-7">
            <%= f.text_field :telephone_number, class: "form-control", placeholder: "0000000000" %>
          </div>
        </div>

        <!-- パスワード -->
        <div class="form-group row">
          <label class="col-md-3 col-form-label">パスワード(6文字以上)</label>
          <div class="col-md-7">
            <%= f.password_field :password, autocomplete: "new-password", class: "form-control" %>
          </div>
        </div>

        <!-- パスワード確認 -->
        <div class="form-group row">
          <label class="col-md-3 col-form-label">パスワード(確認用)</label>
          <div class="col-md-7">
            <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "form-control" %>
          </div>
        </div>

        <!-- 登録ボタン -->
        <div class="form-group row mt-4 mb-5">
          <div class="col-md-3"></div>
          <div class="col-md-7">
            <%= f.submit "新規登録", class: "btn btn-success px-5" %>
          </div>
        </div>
      <% end %>

      <!-- ログイン誘導 -->
      <div class="row">
        <div class="col-md-12">
          <h5 class="mb-3"><span class="bg-light px-4 py-2">既に登録済みの方</span></h5>
        </div>
      </div>

      <div class="row mb-5">
        <div class="col-md-10 offset-md-1">
          <p>
            <%= link_to "こちら", new_customer_session_path, class: "text-primary text-decoration-underline" %>
            からログインしてください。
          </p>
        </div>
      </div>

    </div>
  </div>
</div>